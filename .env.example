# PulseBoard Platform - Environment Variables

# User API Service
USER_API_PORT=5001
JWT_SECRET=change-me-in-production
TOKEN_EXPIRY_HOURS=24
# 登録時に要求するパスワードの最小文字数
MIN_PASSWORD_LENGTH=6
# GET /api/users のページネーション既定値・上限
USERS_DEFAULT_LIMIT=50
USERS_MAX_LIMIT=200

# Analytics Engine
ANALYTICS_PORT=5002
# インメモリに保持するイベント数の上限（超過分は古いものから破棄）
MAX_EVENTS=10000
# /api/analytics/track のリクエストボディ最大バイト数
MAX_BODY_BYTES=1048576

# Notification Service
NOTIFICATION_PORT=5003

# General
LOG_LEVEL=INFO
